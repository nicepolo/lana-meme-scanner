# ── LANA Meme Scanner 環境變數 ──────────────────────────────
# 複製此檔為 .env，或直接在 Railway Variables 頁面填入

# Telegram（必填）— 沿用你現有的 LANA bot
TELEGRAM_BOT_TOKEN=你的_bot_token
TELEGRAM_CHAT_ID=你的_chat_id

# Claude API（強烈建議填入，可做 AI 多空分析）
# 沒填也能跑，會改用規則式備用分析
ANTHROPIC_API_KEY=你的_anthropic_api_key

# 掃描設定（可選，有預設值）
MEME_SCAN_INTERVAL_MIN=15     # 掃描間隔，分鐘
MIN_SCORE_TO_ALERT=60          # 訊號強度門檻，0-100
